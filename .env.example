APP_NAME=BIMFree

DATABASE_URL=postgresql://username:password@localhost:5432/BIMFree_db

MODEL_SERVER_URL=http://example.com
MODEL_SERVER_TRANSFORM_PATH=/transform
MODEL_SERVER_TIMEOUT_SECONDS=300

POSTGRES_IMAGE=postgres:16
POSTGRES_CONTAINER_NAME=BIMFree_postgres
POSTGRES_RESTART_POLICY=always
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=BIMFree_db
POSTGRES_PORT=5432

API_PUBLIC_DOMAIN=api.example.com
HTTP_PORT=80
HTTPS_PORT=443

MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
MINIO_CONTAINER_NAME=BIMFree_minio
MINIO_INIT_CONTAINER_NAME=BIMFree_minio_init
MINIO_RESTART_POLICY=always
MINIO_ROOT_USER=username
MINIO_ROOT_PASSWORD=password
MINIO_BUCKET_NAME=scan-files
MINIO_PUBLIC_DOMAIN=storage.example.com
MINIO_PUBLIC_SCHEME=https
MINIO_REGION=us-east-1
MINIO_PRESIGNED_URL_EXPIRES_SECONDS=900
FRONTEND_ORIGIN=https://app.example.com

CADDY_IMAGE=caddy:2-alpine
CADDY_CONTAINER_NAME=BIMFree_caddy
CADDY_RESTART_POLICY=always
